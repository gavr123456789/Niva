emptyListTypeInference = [
  fileMain = """
    type Sas x: List(Int)
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  db = result db
  typedAst = result entryPointExpressions
  sasType = db packages at: "main", unpackOrPANIC,
               types at: "Sas", unpackOrPANIC asTypeT
  fieldType = sasType fields first typeT asListT t
  Assert that: fieldType name equals: "Int"
]

empty2 = [
  fileMain = """
    type Sas x: List(Int)
    Sas x: {}
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  db = result db
  typedAst = result entryPointExpressions


  >typedAst last typeInfo t toString
]
