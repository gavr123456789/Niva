odin = [
  program = "+ + * ) - /"
  acc <- 0
  program forEach: [
    | it
    | '+' => acc <- acc inc
    | '-' => acc <- acc dec
    | '*' => acc <- acc * 2
    | '/' => acc <- acc / 2
    | ')'=> acc <- acc * acc
    |=> []
  ]
  "The program $program calculates the value $acc" echo
]
