Test goNullableTypeCodegen = [
  fileMain = """
    type Person
      name: String

    type Holder
      maybeAge: Int?
      maybePerson: Person?
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  go contains: "maybeAge *int", assertTrue
  go contains: "maybePerson *main_Person", assertTrue
]

Test goWhileTrueCodegen = [
  fileMain = """
    mut c = 3
    [c > 0] whileTrue: [c <- c - 1]
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  go contains: "for {", assertTrue
  go contains: "if !(", assertTrue
  go contains: ") { break }", assertTrue
  go contains: ")()", assertTrue
]

Test goDestructureCodegen = [
  fileMain = """
    type Person
      name: String
      age: Int

    alice = Person name: "Alice" age: 24
    {age name} = alice
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  go contains: "var age int = __destructTmp.age", assertTrue
  go contains: "var name string = __destructTmp.name", assertTrue
]

Test goNestedMatchCodegen = [
  fileMain = """
    x = 1
    y = 2
    res = | x
    | 1 => | y
            | 2 => 10
            |=> 20
    |=> 30
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  go contains: "__matchSubject :=", assertTrue
  go contains: "return func()", assertTrue
]

Test goLambdaArgCodegen = [
  fileMain = """
    {1 2 3} forEach: [item::Int -> item echo]
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  go contains: "func(item int)", assertTrue
]

Test goBindPlaceholder10 = [
  fileMain = """
    Int sumMany: a::Int b::Int c::Int d::Int e::Int f::Int g::Int h::Int i::Int j::Int k::Int -> Int = [
      ^ Bind emit: "$10 + $1" backend: "go" args: {a b c d e f g h i j k}
    ]
    x = 0 sumMany: 1 b: 2 c: 3 d: 4 e: 5 f: 6 g: 7 h: 8 i: 9 j: 10 k: 11
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  go contains: "return j + a", assertTrue
]

Test goFuncNameFromId = [
  Assert that: ("main.main_Int.add" goFuncNameFromId) equals: "main__Int__add"
  Assert that: ("util_util_List.add" goFuncNameFromId) equals: "util__List__add"
  Assert that: ("math.core_Int.plus" goFuncNameFromId) equals: "math__Int__plus"
  Assert that: ("core_Int.==" goFuncNameFromId) equals: "core__Int__equals"
  Assert that: ("main_Point.set:" goFuncNameFromId) equals: "main__Point__set"
  Assert that: ("foo.core_List?.map" goFuncNameFromId) equals: "foo__List_Nullable__map"
  Assert that: ("type" goFuncNameFromId) equals: "type_"
]
