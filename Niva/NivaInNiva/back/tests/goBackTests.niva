Test goTaggedUnionShapes = [
  fileMain = """
    type Point
      x: Int
      y: Int

    union Shape =
    | Rectangle width: Int height: Int
    | Circle radius: Int

    Shape area -> Int =
    | this
    | Rectangle => width * height
    | Circle => radius * radius * 3
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  Assert that: (go contains: "type main_Point struct {") equals: true
  Assert that: (go contains: "type main_Shape interface { ismain_Shape() }") equals: true
  Assert that: (go contains: "type main_Rectangle struct {") equals: true
  Assert that: (go contains: "type main_Circle struct {") equals: true
  Assert that: (go contains: "func (main_Rectangle) ismain_Shape() {}") equals: true
  Assert that: (go contains: "func (main_Circle) ismain_Shape() {}") equals: true
  Assert that: (go contains: "func main__Shape__area") equals: true
  Assert that: (go contains: "switch __matchSubject.(type) {") equals: true
  Assert that: (go contains: "case main_Rectangle:") equals: true
  Assert that: (go contains: "case main_Circle:") equals: true
]

Test goShadowCopyCodegen = [
  fileMain = """
    type Person
      name: String
      age: Int

    p = Person name: "Alice" age: 24
    p2 = p age: 25
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  Assert that: (go contains: "main_Person{p.name, 25}") equals: true
]

Test goBindingsReadFile = [
  fileMain = """
    Int read: String -> String = [
      Bind addImport: "os" backend: "go"
      ^ Bind emit: "os.ReadFile($1)" backend: "go" args: {read}
    ]
    x = 1 read: "file.txt"
    x echo
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  go = GoBackend fullFromResolver: result

  Assert that: (go contains: "import (") equals: true
  Assert that: (go contains: "\"niva_go/core\"") equals: true
  Assert that: (go contains: "\"os\"") equals: true
  Assert that: (go contains: "func main__Int__read") equals: true
  Assert that: (go contains: "os.ReadFile(read)") equals: true
  Assert that: (go contains: "main__Int__read(1, \"file.txt\")") equals: true
]
