Test callNewFromOtherFile = [
  otherFile = """
    type Person
      name: String
  """
  fileMain = """
    alice = Person name: "Alice"
  """

  result = ResolverHelper resolve: #{"main" fileMain
                                     "person" otherFile}
                          entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  js contains: "const alice = new person.Person(\"Alice\")", assertTrue
]

Test multilineStrings = [
  quote = '"' toString
  triple = quote + quote + quote
  fileMain = triple + "escaped\n \\n \\t\nString" + triple

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  js contains: "`escaped", assertTrue
  js contains: "\\\\n \\\\t", assertTrue
  js contains: "String`", assertTrue
]

Test keywordCallMangled = [
  fileMain = """
    String escape =
      this replace: "\\" with: "\\\\"
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  js contains: "String__replace__with", assertTrue
]

Test keywordDeclExternalName = [
  fileMain = """
    String surroundWith(x): String =
      x + this + x
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  js contains: "export function String__surroundWith", assertTrue
]


Test tsGetterCodegen = [
  fileMain = """
    type Person age: Int

    Int twice -> Int = [
      ^ this + this
    ]

    x = 5
    y = x twice

    p = Person age: 21
    z = p age
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  js contains: "export class Person", assertTrue
  js contains: "constructor(age)", assertTrue
  js contains: "this.age = age", assertTrue
  js contains: "export function Int__twice", assertTrue
  js contains: "return ((_this) + (_this))", assertTrue

  js contains: "const x = 5", assertTrue
  js contains: "const y = Int__twice(x)", assertTrue
  js contains: "const p = new Person(21)", assertTrue
  js contains: "const z = p.age", assertTrue
]

Test tsDestructAssignCodegen = [
  fileMain = """
    type Person
      name: String
      age: Int

    alice = Person name: "Alice" age: 24
    {age name} = alice
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  js contains: "const {age, name} = alice", assertTrue
]

Test tsSingleExprReturnCodegen = [
  fileMain = """
    type Square side: Int

    Square perimeter = side inc

    square = Square side: 42
    square perimeter echo
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  js contains: "export function Square__perimeter", assertTrue
  js contains: "let side = _this.side", assertTrue
  js contains: "return core.Int__inc(side)", assertTrue
]

Test tsConstructorOnCoreTypeCodegen = [
  fileMain = """
    constructor Int answear = 42
    Int foo = [
      x = Int answear
    ]
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  js contains: "export function Int__answear", assertTrue
  js contains: "const x = Int__answear()", assertTrue
  Assert that: (js contains: "new Int") equals: false
]

Test tsShadowCopyCodegen = [
  fileMain = """
    type Person
      name: String
      age: Int

    p = Person name: "Alice" age: 24
    p2 = p age: 25
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  js contains: "const p = new Person(\"Alice\", 24)", assertTrue
  js contains: "const p2 = new Person(p.name, 25)", assertTrue
]

Test tsBindingsCodegen = [
  fileMain = """
    Int read: String -> String = [
      Bind addImport: "fs" backend: "js"
      ^ Bind emit: "fs.readFileSync($1, $2)" backend: "js" args: {read "UTF-8"}
    ]
    x = 1 read: ".niva_js/testss.niva"
    x echo
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  js contains: "import * as fs from \"fs\"", assertTrue
  js contains: "export function Int__read(_this, read)", assertTrue
  js contains: "fs.readFileSync(read, \"UTF-8\")", assertTrue
  js contains: "const x = Int__read(1, \".niva_js/testss.niva\")", assertTrue
]

Test tsBindingsBackendFilter = [
  fileMain = """
    Int read: String -> String = [
      Bind addImport: "fs" backend: "go"
      ^ Bind emit: "fs.readFileSync($1, $2)" backend: "go" args: {read "UTF-8"}
    ]
    x = 1 read: ".niva_js/testss.niva"
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  Assert that: (js contains: "import * as fs from \"fs\"") equals: false
  Assert that: (js contains: "fs.readFileSync") equals: false
]

Test tsBindingsEmitBackendNoArgs = [
  fileMain = """
    Int now -> Int = [
      ^ Bind emit: "Date.now()" backend: "js"
    ]
    x = 1 now
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  js contains: "Date.now()", assertTrue
]

