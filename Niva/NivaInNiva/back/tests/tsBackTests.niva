Test callNewFromOtherFile = [
  otherFile = """
    type Person
      name: String
  """
  fileMain = """
    alice = Person name: "Alice"
  """

  result = ResolverHelper resolve: #{"main" fileMain
                                     "person" otherFile}
                          entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  Assert that: (js contains: "const alice = new person.Person(\"Alice\")") equals: true
]

Test multilineStrings = [
  quote = '"' toString
  triple = quote + quote + quote
  fileMain = triple + "escaped\n \\n \\t\nString" + triple

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  Assert that: (js contains: "`escaped") equals: true
  Assert that: (js contains: "\\\\n \\\\t") equals: true
  Assert that: (js contains: "String`") equals: true
]

Test keywordCallMangled = [
  fileMain = """
    String escape =
      this replace: "\\" with: "\\\\"
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  Assert that: (js contains: "String__replace__with") equals: true
]

Test keywordDeclExternalName = [
  fileMain = """
    String surroundWith(x): String =
      x + this + x
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  Assert that: (js contains: "export function String__surroundWith") equals: true
]


Test tsGetterCodegen = [
  fileMain = """
    type Person age: Int

    Int twice -> Int = [
      ^ this + this
    ]

    x = 5
    y = x twice

    p = Person age: 21
    z = p age
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC
  Assert that: (js contains: "export class Person") equals: true
  Assert that: (js contains: "constructor(age)") equals: true
  Assert that: (js contains: "this.age = age") equals: true
  Assert that: (js contains: "export function Int__twice") equals: true
  Assert that: (js contains: "return ((_this) + (_this))") equals: true

  Assert that: (js contains: "const x = 5") equals: true
  Assert that: (js contains: "const y = Int__twice(x)") equals: true
  Assert that: (js contains: "const p = new Person(21)") equals: true
  Assert that: (js contains: "const z = p.age") equals: true
]

Test tsDestructAssignCodegen = [
  fileMain = """
    type Person
      name: String
      age: Int

    alice = Person name: "Alice" age: 24
    {age name} = alice
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  Assert that: (js contains: "const {age, name} = alice") equals: true
]

Test tsSingleExprReturnCodegen = [
  fileMain = """
    type Square side: Int

    Square perimeter = side inc

    square = Square side: 42
    square perimeter echo
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  Assert that: (js contains: "export function Square__perimeter") equals: true
  Assert that: (js contains: "let side = _this.side") equals: true
  Assert that: (js contains: "return core.Int__inc(side)") equals: true
]

Test tsConstructorOnCoreTypeCodegen = [
  fileMain = """
    constructor Int answear = 42
    Int foo = [
      x = Int answear
    ]
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  Assert that: (js contains: "export function Int__answear") equals: true
  Assert that: (js contains: "const x = Int__answear()") equals: true
  Assert that: (js contains: "new Int") equals: false
]

Test tsShadowCopyCodegen = [
  fileMain = """
    type Person
      name: String
      age: Int

    p = Person name: "Alice" age: 24
    p2 = p age: 25
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  Assert that: (js contains: "const p = new Person(\"Alice\", 24)") equals: true
  Assert that: (js contains: "const p2 = new Person(p.name, 25)") equals: true
]

Test tsBindingsCodegen = [
  fileMain = """
    Int read: String -> String = [
      Bind addImport: "fs"
      ^ Bind emit: "fs.readFileSync($1, $2)" args: {read "UTF-8"}
    ]
    x = 1 read: ".niva_js/testss.niva"
    x echo
  """

  result = ResolverHelper resolve: #{"main" fileMain} entryPoint: "main"
  fileToJs = TypeScript fullFromResolver: result
  js = fileToJs at: "main", unpackOrPANIC

  Assert that: (js contains: "import * as fs from \"fs\"") equals: true
  Assert that: (js contains: "export function Int__read(_this, read)") equals: true
  Assert that: (js contains: "fs.readFileSync(read, \"UTF-8\")") equals: true
  Assert that: (js contains: "const x = Int__read(1, \".niva_js/testss.niva\")") equals: true
]

