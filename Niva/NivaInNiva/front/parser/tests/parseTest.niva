type TestParse
constructor TestParse withInput: String expectedCount: Int -> mut List::Statement = [
  tokens = Lexer get-tokens: withInput
  // tokens debug
  // {statements} = Parser newParseTokens: tokens
  parser = Parser newParseTokens: tokens
  statements::mut List(Statement) = parser statements

  expectedCount > 0 ifTrue: [
    Assert that: statements count equals: expectedCount
  ]

  ^statements
]

constructor TestParse expression::String -> Expr = [
  expr = Parser newParseTokens: (Lexer get-tokens: expression), statements at: 0

  ^ | expr
    | Expr => expr
    |=> [TO DO: "It should be Expr, but it " + expr toString]
]

Test varDeclarationWithAstType  = [
  input = """
    x::Int = 42
  """
  statements = TestParse withInput: input expectedCount: 1
  vardecl = statements at: 0
  | vardecl
  | VarDeclaration => [
    Assert that: vardecl astType unpackOrPANIC name equals: "Int"
    Assert that: vardecl name equals: "x"
  ]
  |=> [TO DO: "VarDeclaration expected"]

]
Test varDeclarationWithAstType2 = [

  input = """
    Money make::Int sas::String -> Unit = [
      x::Int = 42
    ]
  """
  statements = TestParse withInput: input expectedCount: 1

]


Test comments = [
  input = """
    1 + 2
    //sas
    // uu
    3 / 4
  """
  statements = TestParse withInput: input expectedCount: 2

]


Test parseNumber = [
  input = """
  123
  """ trimIndent

  tokens = Lexer get-tokens: input
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements // {}! error TODO
  intExpr = parser literalExprFrom: tokens first, unpackOrPANIC
  | intExpr
  | IntExpr =>
    Assert
      that: intExpr num
      equals: 123
  |=> [TO DO: "It should be int, but it $intExpr"]
]

Test parseString = [
  tokens = Lexer get-tokens: """ "sas" """
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements // {}! error TODO
  stringExpr = parser literalExprFrom: tokens first, unpackOrPANIC
  | stringExpr
  | StringExpr =>
    Assert
      that: stringExpr token lexeme
      equals: "\"sas\""
  |=> [TO DO: "It should be int, but it " + stringExpr toString]
]





Test parseAstTypeList = [
  input = """
    List::List::Int
  """ trimIndent

  tokens = Lexer get-tokens: input
  // tokens debug
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements // {}! error TODO
  astType = parser parseType
  | astType
  | AstType => [
    Assert that: astType genericParams count equals: 1
    list = astType genericParams at: 0
    | list
    | AstType => Assert that: list name equals: "List"
    |=> TO DO: "Wrong type"
  ]
  |=> [TO DO: "It should be List, but it " + astType toString]

]

Test parseAstTypeMap = [
  input = """
    Map(Int, String)
  """ trimIndent

  tokens = Lexer get-tokens: input
  // tokens debug
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements // {}! error TODO
  astType = parser parseType

  | astType
  | AstType => [
    Assert that: astType genericParams count equals: 2
    int = astType genericParams at: 0
    | int
    | AstType => Assert that: int name equals: "Int"
    |=> TO DO: "Wrong type"

    string = astType genericParams at: 1
    | string
    | AstType => Assert that: string name equals: "String"
    |=> TO DO: "Wrong type"
  ]
  |=> [TO DO: "It should be Map, but it " + astType toString]

]

Test parseAstTypeErrorAny = [
  input = """
    Int!
  """ trimIndent

  tokens = Lexer get-tokens: input
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements
  astType = parser parseType

  | astType | AstType => [
    errors = astType errors unpackOrPANIC
    Assert that: errors kind equals: AstTypeErrorsKind.Any
    Assert that: errors names count equals: 0
  ] |=> [TO DO: "It should be AstType, but it " + astType toString]
]

Test parseAstTypeErrorSingle = [
  input = """
    Int!OutOfMemory
  """ trimIndent

  tokens = Lexer get-tokens: input
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements
  astType = parser parseType

  | astType | AstType => [
    errors = astType errors unpackOrPANIC
    Assert that: errors kind equals: AstTypeErrorsKind.Single
    Assert that: errors names count equals: 1
    Assert that: errors names first equals: "OutOfMemory"
  ] |=> [TO DO: "It should be AstType, but it " + astType toString]
]

Test parseAstTypeErrorList = [
  input = """
    Int!{Error1 Error2 Error3}
  """ trimIndent

  tokens = Lexer get-tokens: input
  statements::mut List::Statement = {}!
  parser:: mut Parser = Parser tokens: tokens current: 0 statements: statements
  astType = parser parseType

  | astType | AstType => [
    errors = astType errors unpackOrPANIC
    Assert that: errors kind equals: AstTypeErrorsKind.List
    Assert that: errors names count equals: 3
    Assert that: (errors names at: 0) equals: "Error1"
    Assert that: (errors names at: 1) equals: "Error2"
    Assert that: (errors names at: 2) equals: "Error3"
  ] |=> [TO DO: "It should be AstType, but it " + astType toString]
]

Test parseExtendMessageDeclarations = [
  input = """
    extend FooBar [
      on foo: Int bar: Int = []
      on foo = []
      on + x: Int = []
    ]
  """

  statements = TestParse withInput: input expectedCount: 1
  extendDecl = statements at: 0

  | extendDecl
  | ExtendDecl => [
    Assert that: extendDecl receiver name equals: "FooBar"
    Assert that: extendDecl messages count equals: 3

    first = extendDecl messages at: 0
    second = extendDecl messages at: 1
    third = extendDecl messages at: 2

    Assert that: first receiver name equals: "FooBar"
    Assert that: first name equals: "foo__bar"
    Assert that: second receiver name equals: "FooBar"
    Assert that: second name equals: "foo"
    Assert that: third receiver name equals: "FooBar"
    Assert that: third name equals: "+"
  ]
  |=> [TO DO: "ExtendDecl expected"]
]
