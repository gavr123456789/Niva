  | this | TypedExpr => this
  |=> TO DO: "Its not TypedExpr, its $this"

Statement toTyped -> TypedExpr =
  | this | TypedExpr => this
  |=> TO DO: "Its not TypedExpr, its $this"


TypedExpr2 isIdentifierConstructor = | this
| IdentifierT => [this isNameOfTheType]
|=> [false]
